# PostgreSQL connection string used by Prisma (prisma.config.ts) and the app.
DATABASE_URL="postgresql://user:password@localhost:5432/recipe_book?schema=public"

# Auth.js session/cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-generated-secret"

# Trust the Host header. Required when running behind a reverse proxy or in
# production so Auth.js can build correct absolute callback URLs. The app reads
# this as a boolean: set to "true" to enable, anything else (or unset) disables
# it for local development.
AUTH_TRUST_HOST="true"

# Optional. When set, the API enables CORS for this origin with credentials,
# so a cross-domain frontend can read the Auth.js session cookie via GET /me.
# Leave unset for same-origin deployments. Cross-origin cookies also require
# SameSite=None; Secure on the Auth.js session cookie (deployment concern).
# FRONTEND_ORIGIN="https://your-frontend.example.com"

# Google OAuth credentials from Google Cloud Console > APIs & Services >
# Credentials (OAuth 2.0 Client ID). The authorized redirect URI must be set to
#   http://localhost:3000/auth/callback/google  (local dev)
#   https://<your-domain>/auth/callback/google   (production)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# HTTP port the API listens on.
PORT=3000
